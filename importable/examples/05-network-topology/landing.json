            "hiddenStyle": {},
            "metricStyle": {
              "alias": "",
              "colorMode": "row",
              "colors": ["#8a8a8a", "#299c46", "#f53636", "#0a55a1"],
              "decimals": "0",
              "ignoreNullValues": true,
              "unitFormat": "short",
              "thresholds": [
                { "color": "#8a8a8a", "state": 0, "value": 0 },
