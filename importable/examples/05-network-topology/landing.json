            "label": "Speed",
            "enabled": true,
            "order": 0,
            "align": "default",
            "dateStyle": { "dateFormat": "YYYY-MM-DD HH:mm:ss" },
            "hiddenStyle": {},
            "metricStyle": { "alias": "", "colorMode": "disabled", "colors": ["#299c46", "#ed8128", "#f53636", "#0a55a1"], "decimals": "0", "ignoreNullValues": true, "unitFormat": "short", "thresholds": [] },
            "stringStyle": { "clickThrough": "", "clickThroughCustomTarget": "", "clickThroughCustomTargetEnabled": false, "clickThroughOpenNewTab": true, "clickThroughSanitize": true, "splitByPattern": "" }
          },
          {
