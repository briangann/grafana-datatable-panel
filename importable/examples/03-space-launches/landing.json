      "type": "briangann-datatable-panel",
      "title": "Recent Launches Preview",
      "datasource": {
        "type": "yesoreyeram-infinity-datasource",
        "uid": "${DS_INFINITY}"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
