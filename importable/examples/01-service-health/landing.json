    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "11.6.0"
    },
    {
      "type": "datasource",
      "id": "grafana-testdata-datasource",
      "name": "TestData DB",
      "version": "1.0.0"
    }
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0,211,255,1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "type": "stat",
      "title": "Total Services",
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 0 },
      "id": 3,
      "datasource": { "type": "grafana-testdata-datasource", "uid": "${DS_TESTDATA}" },
      "options": { "reduceOptions": { "calcs": ["count"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background", "graphMode": "none" },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "blue" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] } }, "overrides": [] },
      "targets": [{ "datasource": { "type": "grafana-testdata-datasource", "uid": "${DS_TESTDATA}" }, "refId": "A", "scenarioId": "csv_metric_values", "csvContent": "service\nauthentication\napi-gateway\npayment\nnotifications\nsearch\ndatabase" }]
    },
    {
      "type": "stat",
      "title": "Healthy (Error Rate < 1%)",
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 0 },
      "id": 4,
      "datasource": { "type": "grafana-testdata-datasource", "uid": "${DS_TESTDATA}" },
      "options": { "reduceOptions": { "calcs": ["count"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background", "graphMode": "none" },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "green" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] } }, "overrides": [] },
      "targets": [{ "datasource": { "type": "grafana-testdata-datasource", "uid": "${DS_TESTDATA}" }, "refId": "A", "scenarioId": "csv_metric_values", "csvContent": "service\nauthentication\npayment\ndatabase" }]
    },
    {
      "type": "stat",
      "title": "Critical (Error Rate ≥ 5%)",
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 0 },
      "id": 5,
      "datasource": { "type": "grafana-testdata-datasource", "uid": "${DS_TESTDATA}" },
      "options": { "reduceOptions": { "calcs": ["count"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background", "graphMode": "none" },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "red" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }] } }, "overrides": [] },
      "targets": [{ "datasource": { "type": "grafana-testdata-datasource", "uid": "${DS_TESTDATA}" }, "refId": "A", "scenarioId": "csv_metric_values", "csvContent": "service\nnotifications" }]
    },
    {
      "type": "text",
      "title": "About This Example Set",
      "gridPos": { "h": 12, "w": 10, "x": 0, "y": 4 },
      "id": 1,
      "options": {
        "mode": "markdown",
        "content": "## Service Health Monitoring\n\nThis example shows how the **Datatable Panel** turns a table of service metrics into an interactive monitoring dashboard.\n\n### Features demonstrated\n\n- 🟥 **Row coloring** — whole row turns red when any metric is critical\n- 📊 **Cell coloring** — Latency cells colored by threshold independently\n- 🔗 **Clickthrough** — click any service name to open a detail view\n- 👁️ **Hidden columns** — service ID is hidden but passed in the URL\n- 🔍 **Search** — type in the search box to filter services\n\n### Try it\n\n1. Look at the table on the right — notice the color coding\n2. Click a **service name** to drill into that service\n3. The detail dashboard opens with the service pre-selected\n\n[Open Overview →](/d/dt-service-health-overview)",
        "code": { "language": "plaintext", "showLineNumbers": false, "showMiniMap": false }
      }
    },
    {
      "type": "briangann-datatable-panel",
      "title": "Service Health Preview",
      "datasource": { "type": "grafana-testdata-datasource", "uid": "${DS_TESTDATA}" },
      "fieldConfig": { "defaults": { "mappings": [] }, "overrides": [] },
      "gridPos": { "h": 12, "w": 14, "x": 10, "y": 4 },
      "id": 2,
      "options": {
        "alignNumbersToRightEnabled": true,
        "alignStringsToRightEnabled": false,
        "columnAliases": [],
        "columnFiltersEnabled": false,
        "columnSorting": [],
        "columnStylesConfig": [
          {
            "activeStyle": "metric",
            "nameOrRegex": "error_rate",
            "label": "Error Rate",
            "enabled": true,
            "order": 0,
            "align": "default",
            "dateStyle": { "dateFormat": "YYYY-MM-DD HH:mm:ss" },
            "hiddenStyle": {},
            "metricStyle": {
              "alias": "",
              "colorMode": "row",
              "colors": ["#299c46", "#ed8128", "#f53636", "#0a55a1"],
              "decimals": "1",
              "ignoreNullValues": true,
              "unitFormat": "percent",
              "thresholds": [
                { "color": "#299c46", "state": 0, "value": 0 },
                { "color": "#ed8128", "state": 1, "value": 1 },
                { "color": "#f53636", "state": 2, "value": 5 }
              ]
            },
            "stringStyle": { "clickThrough": "", "clickThroughCustomTarget": "", "clickThroughCustomTargetEnabled": false, "clickThroughOpenNewTab": true, "clickThroughSanitize": true, "splitByPattern": "" }
          }
        ],
        "columnWidthHints": [],
        "columns": [],
        "compactRowsEnabled": false,
        "datatablePagingType": "simple_numbers",
        "emptyDataEnabled": true,
        "emptyDataText": "-",
        "fontSizePercent": "100%",
        "hoverEnabled": true,
        "infoEnabled": false,
        "lengthChangeEnabled": false,
        "orderColumnEnabled": false,
        "rowNumbersEnabled": false,
        "rowsPerPage": 6,
        "scroll": false,
        "searchEnabled": false,
        "searchHighlightingEnabled": false,
        "stripedRowsEnabled": true,
        "transformation": "timeseries-to-columns",
        "transformationAggregations": ["last"],
        "wrapToFitEnabled": true
      },
      "targets": [
        {
          "datasource": { "type": "grafana-testdata-datasource", "uid": "${DS_TESTDATA}" },
          "refId": "A",
          "scenarioId": "csv_metric_values",
          "csvContent": "service,error_rate\nauthentication,0.8\napi-gateway,2.1\npayment,0.2\nnotifications,7.3\nsearch,1.5\ndatabase,0.1"
        }
      ],
      "pluginVersion": "2.0.0"
    }
  ],
  "schemaVersion": 39,
  "tags": ["datatable-examples"],
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
